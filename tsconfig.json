{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./types/",
    "module": "nodenext",
    "target": "esnext",
    "types": [
      "node"
    ],
    "checkJs": true,
    "emitDeclarationOnly": true,
    "declaration": true,
    "allowJs": true
  },
  "include": [
    "src/*.ts",
    "src/**/*.js",
    "src/**/**/*.js"
  ]
}
